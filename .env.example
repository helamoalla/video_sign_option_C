POSTGRES_DB=videosign
POSTGRES_USER=videosign
POSTGRES_PASSWORD=replace-in-production

DATABASE_URL=postgresql+psycopg2://videosign:replace-in-production@postgres:5432/videosign
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MAX_REQUEST_BYTES=110100480
MAX_UPLOAD_BYTES=104857600

MAX_MEDIA_DURATION_SECONDS=600
MAX_VIDEO_WIDTH=3840
MAX_VIDEO_HEIGHT=2160
MAX_VIDEO_PIXELS=8294400

MAX_ACTIVE_JOBS_PER_USER=2
DEVELOPMENT_DAILY_JOB_LIMIT=20
STANDARD_DAILY_JOB_LIMIT=100
ENTERPRISE_DAILY_JOB_LIMIT=1000

# Completed outputs are retained for seven days.
OUTPUT_RETENTION_HOURS=168

# Failed-job derivatives are retained for one day.
FAILED_MEDIA_RETENTION_HOURS=24

# Maximum jobs handled in one cleanup transaction.
RETENTION_CLEANUP_BATCH_SIZE=100

# Prototype CWASA/Dicta-Sign assets are permitted only in development.
APP_ENV=development
ALLOW_RESEARCH_ASSETS=true

# Production must use Cyrkil-owned/licensed avatar videos:
# APP_ENV=production
# ALLOW_RESEARCH_ASSETS=false